xCell id="m1" value="1. Submit email and password" style="endArrow=block;html=1;strokeColor=#1f4e79;fontColor=#1f2937;" edge="1" parent="1" source="l1" target="l2"><mxGeometry relative="1" as="geometry"><mxPoint x="250" y="220" as="sourcePoint" /><mxPoint x="350" y="220" as="targetPoint" /></mxGeometry></mxCell><mxCell id="m2" value="2. POST /api/auth/login" style="endArrow=block;html=1;strokeColor=#1f4e79;fontColor=#1f2937;" edge="1" parent="1" source="l2" target="l3"><mxGeometry relative="1" as="geometry"><mxPoint x="520" y="290" as="sourcePoint" /><mxPoint x="650" y="290" as="targetPoint" /></mxGeometry></mxCell><mxCell id="m3" value="3. Query user by email" style="endArrow=block;html=1;strokeColor=#1f4e79;fontColor=#1f2937;" edge="1" parent="1" source="l3" target="l4"><mxGeometry relative="1" as="geometry"><mxPoint x="870" y="360" as="sourcePoint" /><mxPoint x="1010" y="360" as="targetPoint" /></mxGeometry></mxCell><mxCell id="m4" value="4. Return row + password_hash" style="endArrow=open;dashed=1;html=1;strokeColor=#6b7280;fontColor=#374151;" edge="1" parent="1" source="l4" target="l3"><mxGeometry relative="1" as="geometry"><mxPoint x="1010" y="430" as="sourcePoint" /><mxPoint x="870" y="430" as="targetPoint" /></mxGeometry></mxCell><mxCell id="m5" value="5. Return id,email,role" style="endArrow=open;dashed=1;html=1;strokeColor=#6b7280;fontColor=#374151;" edge="1" parent="1" source="l3" target="l2"><mxGeometry relative="1" as="geometry"><mxPoint x="650" y="500" as="sourcePoint" /><mxPoint x="520" y="500" as="targetPoint" /></mxGeometry></mxCell><mxCell id="m6" value="6. login(user)" style="endArrow=block;html=1;strokeColor=#1f4e79;fontColor=#1f2937;" edge="1" parent="1" source="l2" target="l5"><mxGeometry relative="1" as="geometry"><mxPoint x="520" y="570" as="sourcePoint" /><mxPoint x="1310" y="570" as="targetPoint" /></mxGeometry></mxCell><mxCell id="m7" value="7. Save session to localStorage" style="endArrow=open;dashed=1;html=1;strokeColor=#6b7280;fontColor=#374151;" edge="1" parent="1" source="l5" target="l2"><mxGeometry relative="1" as="geometry"><mxPoint x="1310" y="640" as="sourcePoint" /><mxPoint x="520" y="640" as="targetPoint" /></mxGeometry></mxCell><mxCell id="m8" value="8. Navigate to /admin or /user" style="endArrow=open;dashed=1;html=1;strokeColor=#6b7280;fontColor=#374151;" edge="1" parent="1" source="l2" target="l1"><mxGeometry relative="1" as="geometry"><mxPoint x="350" y="710" as="sourcePoint" /><mxPoint x="250" y="710" as="targetPoint" /></mxGeometry></mxCell><mxCell id="note" value="Password verification uses bcrypt compare on backend." style="shape=note;whiteSpace=wrap;html=1;strokeColor=#7f7f7f;fillColor=#fff2cc;fontColor=#1f2937;" vertex="1" parent="1"><mxGeometry x="640" y="520" width="260" height="90" as="geometry" /></mxCell></root></mxGraphModel></diagram>
