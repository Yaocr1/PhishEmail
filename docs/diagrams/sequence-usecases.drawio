        <mxCell id="m6" value="6. Return threshold row" style="endArrow=open;dashed=1;html=1;strokeColor=#6b7280;fontColor=#374151;" edge="1" parent="1" source="l5" target="l3"><mxGeometry relative="1" as="geometry"><mxPoint x="1260" y="560" as="sourcePoint"/><mxPoint x="840" y="560" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="m7" value="7. Insert phish_email_scans" style="endArrow=block;html=1;strokeColor=#1f4e79;fontColor=#1f2937;" edge="1" parent="1" source="l3" target="l5"><mxGeometry relative="1" as="geometry"><mxPoint x="840" y="630" as="sourcePoint"/><mxPoint x="1260" y="630" as="targetPoint"/></mxGeometry></mxCell>
