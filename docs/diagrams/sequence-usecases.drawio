        <mxCell id="m1" value="1. Enter subject, sender, body" style="endArrow=block;html=1;strokeColor=#1f4e79;fontColor=#1f2937;" edge="1" parent="1" source="l1" target="l2"><mxGeometry relative="1" as="geometry"><mxPoint x="210" y="210" as="sourcePoint"/><mxPoint x="280" y="210" as="targetPoint"/></mxGeometry></mxCell>
