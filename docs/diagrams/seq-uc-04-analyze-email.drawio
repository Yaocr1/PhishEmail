etry" /></mxCell><mxCell id="m1" value="1. Enter subject, sender, body" style="endArrow=block;html=1;strokeColor=#1f4e79;fontColor=#1f2937;" edge="1" parent="1" source="l1" target="l2"><mxGeometry relative="1" as="geometry"><mxPoint x="210" y="210" as="sourcePoint" /><mxPoint x="280" y="210" as="targetPoint" /></mxGeometry></mxCell><mxCell id="m2" value="2. POST /api/analyze" style="endArrow=block;html=1;strokeColor=#1f4e79;fontColor=#1f2937;" edge="1" parent="1" source="l2" target="l3"><mxGeometry relative="1" as="geometry"><mxPoint x="520" y="280" as="sourcePoint" /><mxPoint x="620" y="280" as="targetPoint" /></mxGeometry></mxCell><mxCell id="m3" value="3. Call HF /predict" style="endArrow=block;html=1;strokeColor=#1f4e79;fontColor=#1f2937;" edge="1" parent="1" source="l3" target="l4"><mxGeometry relative="1" as="geometry"><mxPoint x="840" y="350" as="sourcePoint" /><mxPoint x="940" y="350" as="targetPoint" /></mxGeometry></mxCell><mxCell id="m4" value="4. Return label + confidence + phishing_prob" style="endArrow=open;dashed=1;html=1;strokeColor=#6b7280;fontColor=#374151;" edge="1" parent="1" source="l4" target="l3"><mxGeometry relative="1" as="geometry"><mxPoint x="940" y="420" as="sourcePoint" /><mxPoint x="840" y="420" as="targetPoint" /></mxGeometry></mxCell><mxCell id="m5" value="5. Read phishing_threshold" style="endArrow=block;html=1;strokeColor=#1f4e79;fontColor=#1f2937;" edge="1" parent="1" source="l3" target="l5"><mxGeometry relative="1" as="geometry"><mxPoint x="840" y="490" as="sourcePoint" /><mxPoint x="1260" y="490" as="targetPoint" /></mxGeometry></mxCell><mxCell id="m6" value="6. Return threshold row" style="endArrow=open;dashed=1;html=1;strokeColor=#6b7280;fontColor=#374151;" edge="1" parent="1" source="l5" target="l3"><mxGeometry relative="1" as="geometry"><mxPoint x="1260" y="560" as="sourcePoint" /><mxPoint x="840" y="560" as="targetPoint" /></mxGeometry></mxCell><mxCell id="m7" value="7. Insert phish_email_scans" style="endArrow=block;html=1;strokeColor=#1f4e79;fontColor=#1f2937;" edge="1" parent="1" source="l3" target="l5"><mxGeometry relative="1" as="geometry"><mxPoint x="840" y="630" as="sourcePoint" /><mxPoint x="1260" y="630" as="targetPoint" /></mxGeometry></mxCell><mxCell id="m8" value="8. Return saved scan" style="endArrow=open;dashed=1;html=1;strokeColor=#6b7280;fontColor=#374151;" edge="1" parent="1" source="l5" target="l3"><mxGeometry relative="1" as="geometry"><mxPoint x="1260" y="700" as="sourcePoint" /><mxPoint x="840" y="700" as="targetPoint" /></mxGeometry></mxCell><mxCell id="m9" value="9. Return verdict JSON" style="endArrow=open;dashed=1;html=1;strokeColor=#6b7280;fontColor=#374151;" edge="1" parent="1" source="l3" target="l2"><mxGeometry relative="1" as="geometry"><mxPoint x="620" y="770" as="sourcePoint" /><mxPoint x="520" y="770" as="targetPoint" /></mxGeometry></mxCell><mxCell id="m10" value="10. Render phishing/legitimate result" style="endArrow=open;dashed=1;html=1;strokeColor=#6b7280;fontColor=#374151;" edge="1" parent="1" source="l2" target="l1"><mxGeometry relative="1" as="geometry"><mxPoint x="280" y="840" as="sourcePoint" /><mxPoint x="210" y="840" as="targetPoint" /></mxGeometry></mxCell><mxCell id="note" value="If HF endpoint fails, API returns explicit error: 'model is sleeping at HF.'" style="shape=note;whiteSpace=wrap;html=1;strokeColor=#7f7f7f;fillColor=#fff2cc;fontColor=#1f2937;" vertex="1" parent="1"><mxGeometry x="960" y="780" width="400" height="95" as="geometry" /></mxCell></root></mxGraphModel></diagram>
